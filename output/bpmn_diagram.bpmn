    <sequenceFlow id="flow_5" name="lab route" sourceRef="gw_split1" targetRef="lab_loop">
      <conditionExpression xsi:type="tFormalExpression">{score &lt;= 50}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_6" name="IV route" sourceRef="gw_split1" targetRef="iv_liquid">
      <conditionExpression xsi:type="tFormalExpression">${score &gt; 50}</conditionExpression>
